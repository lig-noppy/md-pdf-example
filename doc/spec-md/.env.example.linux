# Linux / WSL2 (bash) 向け — cp .env.example.linux .env
# WORK_VOLUME_SOURCE は未設定でよい（compose.yaml の ./work を使用）

# locale (compose environment でコンテナに渡す)
LANG=ja_JP.UTF-8
LANGUAGE=ja_JP:ja
LC_ALL=ja_JP.UTF-8

# compose: 出力ファイルの所有者をホストユーザー(id -u / id -g の値)に揃える (未設定時 compose デフォルトは 1000:1000)
UID=1000
GID=1000
