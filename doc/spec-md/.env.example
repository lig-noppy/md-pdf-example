# locale (コンテナ内ロケール・Chromium フォント選択)
# docker run --env-file / compose env_file で渡す
LANG=ja_JP.UTF-8
LANGUAGE=ja_JP:ja
LC_ALL=ja_JP.UTF-8

# compose: ホストユーザーと同じ UID/GID で実行 (Linux / WSL2)
# UID=1000
# GID=1000

# Windows (Docker Desktop + WSL2) でのボリュームパス変換
# Windows 絶対パス (C:/...) を Docker デーモン (WSL2 Linux) が解釈できる形式に変換する
COMPOSE_CONVERT_WINDOWS_PATHS=1
