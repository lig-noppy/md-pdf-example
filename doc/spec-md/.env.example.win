# Windows (PowerShell / cmd, Docker Desktop WSL2 backend) 向け
# cp .env.example.win .env のあと WORK_VOLUME_SOURCE を編集するか、.\init-env.ps1 を実行

# locale (compose environment でコンテナに渡す)
LANG=ja_JP.UTF-8
LANGUAGE=ja_JP:ja
LC_ALL=ja_JP.UTF-8

# compose: Windows bind mount では root で実行する
UID=0
GID=0

# compose: WSL マウントパスで bind mount（init-env.ps1 が自動設定）
WORK_VOLUME_SOURCE=/mnt/c/Users/<user>/path/to/spec-md/work
